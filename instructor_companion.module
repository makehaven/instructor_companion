<?php

/**
 * @file
 * Primary module hooks for Instructor Companion.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;
use Drupal\node\Entity\Node;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\HtmlCommand;
use Drupal\webform\WebformSubmissionInterface;

/**
 * Implements hook_cron().
 */
function instructor_companion_cron() {
  // Sync all course stats once a day or on a schedule.
  \Drupal::service('instructor_companion.stats_sync')->sync();
}

/**
 * Implements hook_entity_insert().
 *
 * Posts Slack notifications for new Workshop Proposal / Instructor Interest
 * submissions so staff see the backlog. Handled webforms are listed in
 * ProposalNotifier::HANDLED_WEBFORMS.
 */
function instructor_companion_entity_insert(EntityInterface $entity) {
  if ($entity instanceof WebformSubmissionInterface) {
    \Drupal::service('instructor_companion.proposal_notifier')
      ->notifyForSubmission($entity);
  }
}

/**
 * Implements hook_civicrm_event_insert().
 */
function instructor_companion_civicrm_event_insert(\Drupal\Core\Entity\EntityInterface $entity) {
  // If this event was created as inactive, it's a proposal.
  if (!$entity->get('is_active')->value) {
    $mailManager = \Drupal::service('plugin.manager.mail');
    $module = 'instructor_companion';
    $key = 'new_proposal_submitted';
    $config = \Drupal::config('instructor_companion.settings');
    $to = $config->get('notification_email') ?: \Drupal::config('system.site')->get('mail');
    
    $params['event_title'] = $entity->label();
    $params['event_link'] = $entity->toUrl('edit-form', ['absolute' => TRUE])->toString();
    $params['user_name'] = \Drupal::currentUser()->getDisplayName();
    
    $mailManager->mail($module, $key, $to, 'en', $params, NULL, TRUE);
    \Drupal::messenger()->addMessage(t('Your proposal has been submitted for staff review.'));
  }

  // Trigger sync for the parent course.
  if ($entity->hasField('field_parent_course') && !$entity->get('field_parent_course')->isEmpty()) {
    $nid = $entity->get('field_parent_course')->target_id;
    \Drupal::service('instructor_companion.stats_sync')->sync((int) $nid);
  }
}

/**
 * Implements hook_civicrm_event_update().
 */
function instructor_companion_civicrm_event_update(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->hasField('field_parent_course') && !$entity->get('field_parent_course')->isEmpty()) {
    $nid = $entity->get('field_parent_course')->target_id;
    \Drupal::service('instructor_companion.stats_sync')->sync((int) $nid);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for user_register_form.
 */
function instructor_companion_form_user_register_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $query = \Drupal::request()->query;
  if ($query->get('profile') === 'instructor') {
    $form['actions']['submit']['#submit'][] = 'instructor_companion_user_register_notify';
  }
}

/**
 * Custom submit handler: Notify staff of new instructor applicant.
 */
function instructor_companion_user_register_notify($form, FormStateInterface $form_state) {
  $user = $form_state->getFormObject()->getEntity();
  $mailManager = \Drupal::service('plugin.manager.mail');
  $module = 'instructor_companion';
  $key = 'new_instructor_applicant';
  $config = \Drupal::config('instructor_companion.settings');
  $to = $config->get('notification_email') ?: \Drupal::config('system.site')->get('mail');
  $params['user_name'] = $user->getAccountName();
  $params['user_email'] = $user->getEmail();
  $params['user_link'] = $user->toUrl()->setAbsolute()->toString();
  $langcode = $user->getPreferredLangcode();
  $mailManager->mail($module, $key, $to, $langcode, $params, NULL, TRUE);
  \Drupal::messenger()->addMessage(t('Your instructor application has been started. Staff have been notified.'));
}

/**
 * Implements hook_mail().
 */
function instructor_companion_mail($key, &$message, $params) {
  switch ($key) {
    case 'new_instructor_applicant':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('New Instructor Application: @name', ['@name' => $params['user_name']]);
      $message['body'][] = t('A new user has registered via the Instructor path.');
      $message['body'][] = t('Name: @name', ['@name' => $params['user_name']]);
      $message['body'][] = t('Email: @email', ['@email' => $params['user_email']]);
      $message['body'][] = t('Profile: @link', ['@link' => $params['user_link']]);
      $message['body'][] = t('Please review their application and assign the Instructor role if approved.');
      break;

    case 'new_proposal_submitted':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('New Session Proposal: @title', ['@title' => $params['event_title']]);
      $message['body'][] = t('An instructor has proposed a new session.');
      $message['body'][] = t('Course: @title', ['@title' => $params['event_title']]);
      $message['body'][] = t('Instructor: @name', ['@name' => $params['user_name']]);
      $message['body'][] = t('Review Proposal: @link', ['@link' => $params['event_link']]);
      break;

    case 'instructor_agreement_signed':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('Instructor Agreement Signed: @name', ['@name' => $params['user_name']]);
      $message['body'][] = t('A member has signed the base instructor agreement and is awaiting approval.');
      $message['body'][] = t('Name: @name', ['@name' => $params['user_name']]);
      $message['body'][] = t('Email: @email', ['@email' => $params['user_email']]);
      $message['body'][] = t('User profile: @link', ['@link' => $params['user_link']]);
      $message['body'][] = t('Next step: review their background and assign the Instructor role when ready. Reply to this email or contact them directly to discuss their first class.');
      break;

    case 'proposal_approved':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('Your session proposal has been approved: @title', ['@title' => $params['event_title']]);
      $message['body'][] = t('Hi @name,', ['@name' => $params['user_name']]);
      $message['body'][] = t('Great news — your proposed session has been approved and is now live on the MakeHaven calendar!');
      $message['body'][] = t('Session: @title', ['@title' => $params['event_title']]);
      if (!empty($params['start_date'])) {
        $message['body'][] = t('Date: @date', ['@date' => $params['start_date']]);
      }
      if (!empty($params['event_link'])) {
        $message['body'][] = t('View your session: @link', ['@link' => $params['event_link']]);
      }
      $message['body'][] = t('Please log into your Instructor Dashboard to review enrollment, request payment, and submit post-class feedback. If you have any questions, reply to this email.');
      $message['body'][] = t('Thank you for teaching at MakeHaven!');
      break;

    case 'proposal_denied':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('Update on your session proposal: @title', ['@title' => $params['event_title']]);
      $message['body'][] = t('Hi @name,', ['@name' => $params['user_name']]);
      $message['body'][] = t('Thank you for submitting a session proposal. After review, we are not able to move forward with this particular proposal at this time.');
      $message['body'][] = t('Session: @title', ['@title' => $params['event_title']]);
      $message['body'][] = t('Reason:');
      $message['body'][] = $params['reason'];
      $message['body'][] = t('We encourage you to reach out if you have questions or would like to discuss other teaching opportunities. You can reply directly to this email or contact education@makehaven.org.');
      break;
  }
}

/**
 * Implements hook_entity_view_alter().
 */
function instructor_companion_node_view_alter(array &$build, \Drupal\Core\Entity\EntityInterface $entity, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display) {
  if ($entity->bundle() === 'course' && $build['#view_mode'] === 'full') {
    $template_id = $entity->get('field_civicrm_template_id')->value;
    $nid = $entity->id();
    
    if (\Drupal::currentUser()->hasPermission('create civicrm_event entities')) {
      $build['schedule_button'] = [
        '#type' => 'link',
        '#title' => t('Schedule This Course'),
        '#url' => \Drupal\Core\Url::fromRoute('entity.civicrm_event.add_form', ['bundle' => 'civicrm_event'], [
          'query' => [
            'template_id' => $template_id,
            'course_id' => $nid,
          ],
        ]),
        '#attributes' => [
          'class' => ['button', 'button--primary', 'button--action'],
          'style' => 'margin-bottom: 20px;',
        ],
        '#weight' => -100,
      ];
    }
  }
}

/**
 * Returns badge terms for which the given user is not yet an approved badger.
 *
 * Being a badger (badge issuer) means the user appears in field_badge_issuer
 * on the badge taxonomy term. That status is granted by staff after the full
 * process: earn the badge → shadow a badger → run a supervised session → staff
 * approval. Simply holding an active badge_request is not sufficient.
 *
 * @param \Drupal\taxonomy\TermInterface[] $badge_terms
 * @param int $uid
 * @return string[] Labels of badges for which the user is not yet a badger.
 */
function instructor_companion_missing_badges(array $badge_terms, int $uid): array {
  if (empty($badge_terms) || !$uid) {
    return [];
  }
  $missing = [];
  foreach ($badge_terms as $badge) {
    $issuer_uids = array_map(
      'intval',
      array_column($badge->get('field_badge_issuer')->getValue(), 'target_id')
    );
    if (!in_array($uid, $issuer_uids, TRUE)) {
      $missing[] = $badge->label();
    }
  }
  return $missing;
}

/**
 * Adds a badge prerequisite warning element to a form.
 *
 * @param array $form
 * @param string[] $missing_badges
 */
function instructor_companion_add_badge_warning(array &$form, array $missing_badges): void {
  $list = implode(', ', array_map(fn($b) => "<strong>$b</strong>", $missing_badges));
  $form['badge_prerequisite_warning'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['messages', 'messages--warning']],
    '#weight' => -20,
    'message' => [
      '#markup' => t(
        'This class awards the following badge(s): !badges. Before teaching it, you\'ll need to become an approved badger for each one. The process is: (1) earn the badge, (2) shadow an existing badger, (3) run a session under supervision, then (4) staff will grant you badger status. Contact education@makehaven.org to get started.',
        ['!badges' => $list]
      ),
    ],
  ];
}

/**
 * Implements hook_form_FORM_ID_alter() for civicrm_event_civicrm_event_add_form.
 */
function instructor_companion_form_civicrm_event_civicrm_event_add_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $query = \Drupal::request()->query;
  $template_id = $query->get('template_id');
  $course_id = $query->get('course_id');
  $is_proposal = $query->get('propose');

  if ($course_id) {
    $course_node = Node::load($course_id);
    if ($course_node && isset($form['field_parent_course'])) {
      $form['field_parent_course']['widget'][0]['target_id']['#default_value'] = $course_node;
    }
    
    if ($course_node) {
      // 1. Fetch and Display Past Instructors.
      $database = \Drupal::database();
      $q = $database->select('civicrm_event__field_civi_event_instructor', 'i');
      $q->join('civicrm_event__field_parent_course', 'f', 'i.entity_id = f.entity_id');
      $q->join('civicrm_event', 'e', 'e.id = i.entity_id');
      $q->join('users_field_data', 'u', 'u.uid = i.field_civi_event_instructor_target_id');
      $q->fields('u', ['display_name', 'name']);
      $q->addExpression('MAX(e.start_date)', 'last_taught');
      $q->condition('f.field_parent_course_target_id', $course_id);
      $q->condition('e.is_active', 1);
      $q->groupBy('u.uid');
      $q->groupBy('u.display_name');
      $q->groupBy('u.name');
      $q->orderBy('last_taught', 'DESC');
      $instructors = $q->execute()->fetchAll();

      if (!empty($instructors)) {
        $instr_list = [];
        foreach ($instructors as $instr) {
          $date = date('M Y', strtotime($instr->last_taught));
          $instr_list[] = "{$instr->display_name} (Last: $date)";
        }
        if (isset($form['field_civi_event_instructor'])) {
          $form['field_civi_event_instructor']['widget']['#description'] = Markup::create(
            '<strong>Past Instructors:</strong> ' . implode(', ', $instr_list)
          );
        }
      }

      // 2. Asset Checking logic with AJAX.
      $required_assets = $course_node->get('field_required_assets')->referencedEntities();
      if (!empty($required_assets)) {
        $asset_names = array_map(fn($a) => $a->getTitle(), $required_assets);
        $asset_ids = array_map(fn($a) => $a->id(), $required_assets);
        
        $form['asset_info'] = [
          '#type' => 'details',
          '#title' => t('Required Assets Check'),
          '#open' => TRUE,
          '#weight' => -5,
          '#attributes' => ['id' => 'asset-check-wrapper'],
          'message' => [
            '#markup' => '<p>This course requires: <strong>' . implode(', ', $asset_names) . '</strong></p>',
          ],
          'conflict_warning' => [
            '#markup' => '<div id="asset-conflict-warning"><em>Select a date/time to check for tool conflicts.</em></div>',
          ],
        ];

        $form['required_asset_ids'] = [
          '#type' => 'hidden',
          '#value' => implode(',', $asset_ids),
        ];

        if (isset($form['start_date'])) {
          $form['start_date']['widget'][0]['value']['#ajax'] = [
            'callback' => 'instructor_companion_check_conflicts_ajax',
            'wrapper' => 'asset-conflict-warning',
            'event' => 'change',
          ];
        }
        if (isset($form['end_date'])) {
          $form['end_date']['widget'][0]['value']['#ajax'] = [
            'callback' => 'instructor_companion_check_conflicts_ajax',
            'wrapper' => 'asset-conflict-warning',
            'event' => 'change',
          ];
        }
      }

      if ($is_proposal) {
        $form['#title'] = t('Propose a Session: @course', ['@course' => $course_node->label()]);
        if (isset($form['is_active'])) {
          $form['is_active']['widget']['#default_value'] = 0;
          $form['is_active']['#access'] = FALSE;
        }
        $pay_type = $course_node->get('field_payment_type')->value;
        $pay_amt = $course_node->get('field_payment_amount')->value;
        $pay_msg = ($pay_type === 'hourly') ? t('$@amt per hour', ['@amt' => $pay_amt]) : t('$@amt fixed total', ['@amt' => $pay_amt]);
        $form['agreement'] = [
          '#type' => 'fieldset',
          '#title' => t('Instructor Agreement'),
          '#weight' => 90,
        ];
        $form['agreement']['terms'] = [
          '#markup' => '<p>' . t('By proposing this session, you agree to the standard MakeHaven instructor terms. Your compensation for this specific course is set at <strong>@pay</strong>, subject to final staff review.', ['@pay' => $pay_msg]) . '</p>',
        ];
        $form['agreement']['accept_terms'] = [
          '#type' => 'checkbox',
          '#title' => t('I accept the instructor agreement for this session.'),
          '#required' => TRUE,
        ];
        if (isset($form['field_civi_event_instructor'])) {
           $form['field_civi_event_instructor']['widget'][0]['target_id']['#default_value'] = \Drupal::currentUser();
        }
      }

      if ($course_node->hasField('field_course_image') && !$course_node->get('field_course_image')->isEmpty()) {
         if (isset($form['field_civi_event_media_image'])) {
            $media_id = $course_node->get('field_course_image')->target_id;
            $form['field_civi_event_media_image']['widget']['#default_value'] = [$media_id];
         }
      }
    }
  }

  if ($template_id) {
    try {
      \Drupal::service('civicrm')->initialize();
      $template = \civicrm_api3('Event', 'getsingle', ['id' => $template_id]);
      $fields = [
        'title' => $template['title'] ?? '',
        'summary' => $template['summary'] ?? '',
        'description' => $template['description'] ?? '',
        'event_type_id' => $template['event_type_id'] ?? NULL,
        'max_participants' => $template['max_participants'] ?? NULL,
        'is_public' => $template['is_public'] ?? 1,
        'is_online_registration' => $template['is_online_registration'] ?? 1,
      ];
      foreach ($fields as $key => $val) {
        if ($val !== NULL && isset($form[$key])) {
          if (isset($form[$key]['widget'][0]['value'])) {
            $form[$key]['widget'][0]['value']['#default_value'] = $val;
          } else {
            $form[$key]['widget']['#default_value'] = $val;
          }
        }
      }

      // Badge prerequisite warning: load the template event entity to read its
      // configured badges, then warn the proposing instructor if they're missing any.
      $template_event = \Drupal::entityTypeManager()
        ->getStorage('civicrm_event')
        ->load($template_id);
      if ($template_event && $template_event->hasField('field_civi_event_badges') && !$template_event->get('field_civi_event_badges')->isEmpty()) {
        $badge_terms = $template_event->get('field_civi_event_badges')->referencedEntities();
        $missing = instructor_companion_missing_badges($badge_terms, \Drupal::currentUser()->id());
        if (!empty($missing)) {
          instructor_companion_add_badge_warning($form, $missing);
        }
      }
    } catch (\Exception $e) {
      \Drupal::logger('instructor_companion')->error('Error pre-filling event: @msg', ['@msg' => $e->getMessage()]);
    }
  }
}

/**
 * Implements hook_form_alter().
 *
 * Prefills the "Instructor" fieldset of the Workshop Proposal webform
 * (webform_497) from the current user's instructor profile so logged-in
 * instructors don't re-enter bio, rate, name, email, etc. every time.
 *
 * Matches by form_id prefix because the webform is rendered via a webform
 * node, which produces a form ID like
 * `webform_submission_webform_497_node_497_add_form`.
 *
 * Anonymous users see the form unchanged — the traveling-instructor flow
 * still works.
 */
function instructor_companion_form_alter(array &$form, FormStateInterface $form_state, string $form_id) {
  if (!str_starts_with($form_id, 'webform_submission_webform_497_')
    || !str_ends_with($form_id, '_add_form')) {
    return;
  }
  $account = \Drupal::currentUser();
  if ($account->isAnonymous()) {
    return;
  }
  $prefill = \Drupal::service('instructor_companion.instructor_profile_resolver')
    ->getPrefillForUser($account);
  if (empty($prefill)) {
    return;
  }

  // Map profile values onto the actual webform element keys. The form_497
  // config uses suffixed names (e.g. your_name_25) from the original build.
  $map = [
    'your_name_25' => $prefill['name'] ?? NULL,
    'e_mail_address_25' => $prefill['email'] ?? NULL,
    'phone_number_25' => $prefill['phone'] ?? NULL,
    'bio_25' => $prefill['bio'] ?? NULL,
    'instructor_compensation_25' => $prefill['compensation'] ?? NULL,
  ];

  if (!isset($form['elements']['fieldset_about_the_instructor'])) {
    return;
  }
  $fieldset = &$form['elements']['fieldset_about_the_instructor'];
  foreach ($map as $key => $value) {
    if ($value === NULL || $value === '') {
      continue;
    }
    if (isset($fieldset[$key])) {
      $fieldset[$key]['#default_value'] = $value;
    }
  }

  // Add a small banner at the top of the fieldset pointing to the profile
  // edit page, so users know they can update their saved data.
  if (!empty($prefill['has_profile'])) {
    $profile_url = \Drupal\Core\Url::fromUserInput('/user/' . $account->id() . '/instructor')->toString();
    $fieldset['saved_profile_banner'] = [
      '#markup' => '<div class="messages messages--status">' .
        t('Using your saved <a href=":url">instructor profile</a>. Update there once and it applies to every proposal.', [':url' => $profile_url]) .
        '</div>',
      '#weight' => -100,
    ];
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for civicrm_event_civicrm_event_edit_form.
 *
 * Warns the assigned instructor (or current user editing) if they lack an active
 * badge for any badge this event awards.
 */
function instructor_companion_form_civicrm_event_civicrm_event_edit_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $event = $form_state->getFormObject()->getEntity();
  if (!$event->hasField('field_civi_event_badges') || $event->get('field_civi_event_badges')->isEmpty()) {
    return;
  }

  // Determine whose badge status to check: prefer the assigned instructor,
  // fall back to the current user.
  $uid = \Drupal::currentUser()->id();
  if ($event->hasField('field_civi_event_instructor') && !$event->get('field_civi_event_instructor')->isEmpty()) {
    $uid = (int) $event->get('field_civi_event_instructor')->target_id;
  }

  $badge_terms = $event->get('field_civi_event_badges')->referencedEntities();
  $missing = instructor_companion_missing_badges($badge_terms, $uid);
  if (!empty($missing)) {
    instructor_companion_add_badge_warning($form, $missing);
  }
}

/**
 * AJAX Callback to check for asset conflicts.
 */
function instructor_companion_check_conflicts_ajax(array &$form, FormStateInterface $form_state) {
  $response = new AjaxResponse();
  $start = $form_state->getValue(['start_date', 0, 'value']);
  $end = $form_state->getValue(['end_date', 0, 'value']);
  $asset_ids_str = $form_state->getValue('required_asset_ids');
  if (!$start || !$end || !$asset_ids_str) {
    return $response->addCommand(new HtmlCommand('#asset-conflict-warning', '<em>Enter both start and end dates to check conflicts.</em>'));
  }
  $start_ts = strtotime($start . ' UTC');
  $end_ts = strtotime($end . ' UTC');
  $asset_ids = explode(',', $asset_ids_str);
  $checker = \Drupal::service('makerspace_reservations.conflict_checker');
  $conflicts_found = [];
  foreach ($asset_ids as $nid) {
    $result = $checker->checkConflicts((int)$nid, $start_ts, $end_ts);
    $asset = Node::load($nid);
    $asset_label = $asset ? $asset->label() : "Asset $nid";
    foreach ($result->getDirectConflicts() as $c) {
      $conflicts_found[] = $checker->formatConflictMessage($c, 'direct', $asset_label);
    }
    foreach ($result->getAncestorConflicts() as $c) {
      $conflicts_found[] = $checker->formatConflictMessage($c, 'ancestor', $asset_label);
    }
    foreach ($result->getDescendantConflicts() as $c) {
      $conflicts_found[] = $checker->formatConflictMessage($c, 'descendant', $asset_label);
    }
  }
  if (!empty($conflicts_found)) {
    $output = '<div class="messages messages--warning">';
    $output .= '<strong>Conflict Warning:</strong><ul><li>' . implode('</li><li>', $conflicts_found) . '</li></ul>';
    $output .= '</div>';
  } else {
    $output = '<div class="messages messages--status">No tool conflicts detected for the selected time.</div>';
  }
  return $response->addCommand(new HtmlCommand('#asset-conflict-warning', $output));
}

/**
 * Implements hook_entity_view_alter() for user entities.
 *
 * Adds a "Become an Instructor" CTA to a member's own profile page when they
 * have indicated teaching availability but don't have an instructor profile yet.
 */
function instructor_companion_user_view_alter(array &$build, \Drupal\Core\Entity\EntityInterface $entity, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display) {
  $current_user = \Drupal::currentUser();

  // Only show on the user's own profile, full view mode.
  if ((int) $entity->id() !== (int) $current_user->id()) {
    return;
  }
  if ($build['#view_mode'] !== 'full') {
    return;
  }
  // Skip if they already have the instructor role.
  if ($current_user->hasRole('instructor')) {
    return;
  }

  // Check main profile for teaching availability.
  $profile_storage = \Drupal::entityTypeManager()->getStorage('profile');
  $main_profiles = $profile_storage->loadByProperties([
    'uid' => $current_user->id(),
    'type' => 'main',
    'status' => 1,
  ]);
  if (empty($main_profiles)) {
    return;
  }

  $main_profile = reset($main_profiles);
  $has_teaching_avail = FALSE;
  foreach ($main_profile->get('field_member_availability') as $item) {
    if (in_array($item->value, ['teach_volunteer', 'teach_paid'], TRUE)) {
      $has_teaching_avail = TRUE;
      break;
    }
  }
  if (!$has_teaching_avail) {
    return;
  }

  // Check whether they've already started the instructor application.
  $instructor_profiles = $profile_storage->loadByProperties([
    'uid' => $current_user->id(),
    'type' => 'instructor',
  ]);
  if (!empty($instructor_profiles)) {
    return;
  }

  // Show the CTA.
  $build['instructor_cta'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['instructor-profile-cta', 'messages', 'messages--status']],
    '#weight' => -50,
    'text' => [
      '#markup' => '<strong>' . t('You indicated interest in teaching — want to make it official?') . '</strong> '
        . '<a href="/become-instructor">' . t('Learn how to become a MakeHaven Instructor') . '</a>.',
    ],
  ];
}

/**
 * Implements hook_preprocess_views_view_field().
 */
function instructor_companion_preprocess_views_view_field(&$variables) {
  $view = $variables['view'];
  $field = $variables['field'];
  $row = $variables['row'];

  if ($view->id() === 'course_library') {
    if ($field->options['id'] === 'rev_per_run') {
      $rev = (float) ($row->node__field_stat_total_rev_field_stat_total_rev_value ?? 0);
      $runs = (int) ($row->node__field_stat_runs_field_stat_runs_value ?? 0);
      $val = $runs > 0 ? $rev / $runs : 0;
      $variables['output'] = Markup::create('$' . number_format($val, 2));
    }
    if ($field->options['id'] === 'rev_per_head') {
      $rev = (float) ($row->node__field_stat_total_rev_field_stat_total_rev_value ?? 0);
      $att = (int) ($row->node__field_stat_total_att_field_stat_total_att_value ?? 0);
      $val = $att > 0 ? $rev / $att : 0;
      $variables['output'] = Markup::create('$' . number_format($val, 2));
    }
  }
}

/**
 * Implements hook_views_pre_view().
 */
function instructor_companion_views_pre_view(\Drupal\views\ViewExecutable $view, $display_id, array &$args) {
  if ($view->id() === 'course_library') {
    // Restrict access to authorized staff only.
    if (!\Drupal::currentUser()->hasPermission('create civicrm_event entities')) {
      $view->access = FALSE;
    }
  }
}

/**
 * Implements hook_views_query_alter().
 */
function instructor_companion_views_query_alter(\Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\QueryPluginBase $query): void {
  if ($view->id() !== 'public_course_catalog') {
    return;
  }

  $view->element['#cache']['contexts'][] = 'url.query_args:sort';

  // Clear the default title sort.
  $query->orderby = [];

  $sort_by = \Drupal::request()->query->get('sort', 'frequency');

  if ($sort_by === 'interest') {
    // LEFT JOIN flag_counts so courses with no votes sort last (count = NULL).
    $configuration = [
      'table'      => 'flag_counts',
      'field'      => 'entity_id',
      'left_table' => 'node_field_data',
      'left_field' => 'nid',
      'extra'      => [
        ['field' => 'flag_id',     'value' => 'course_interest'],
        ['field' => 'entity_type', 'value' => 'node'],
      ],
      'type'       => 'LEFT',
    ];
    /** @var \Drupal\views\Plugin\views\join\JoinPluginBase $join */
    $join = \Drupal::service('plugin.manager.views.join')
      ->createInstance('standard', $configuration);
    $alias = $query->addTable('flag_counts', NULL, $join, 'workshop_flag_counts');
    $query->addOrderBy(NULL, "COALESCE($alias.count, 0)", 'DESC', 'workshop_interest_sort');
  }

  // Secondary (or primary for default): most-offered first.
  $runs_alias = $query->ensureTable('node__field_stat_runs');
  $query->addOrderBy($runs_alias, 'field_stat_runs_value', 'DESC', 'workshop_runs_sort');

  // Deterministic third sort by title.
  $query->addOrderBy('node_field_data', 'title', 'ASC', 'workshop_title_sort');
}
